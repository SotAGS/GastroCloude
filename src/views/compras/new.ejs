<%- include('../layouts/app-shell', {
  title: 'Nueva Compra',
  body: `
    <section class="panel-card">
      <h2 class="section-title mb-3">Registrar compra</h2>
      <p class="mb-3">Carga de ejemplo para probar flujo transaccional. Luego lo conectamos a catalogos dinamicos.</p>
      <form method="post" action="/compras">
        <div class="row g-3">
          <div class="col-md-4">
            <label>Supplier ID</label>
            <input class="form-control" name="supplierId" placeholder="UUID proveedor" required />
          </div>
          <div class="col-md-4">
            <label>Fecha</label>
            <input class="form-control" type="date" name="purchaseDate" required />
          </div>
          <div class="col-12">
            <label>Observaciones</label>
            <input class="form-control" name="observations" />
          </div>
          <div class="col-md-4">
            <label>Producto ID</label>
            <input class="form-control" name="details[0][productId]" placeholder="UUID producto" required />
          </div>
          <div class="col-md-4">
            <label>Cantidad</label>
            <input class="form-control" type="number" step="0.001" min="0.001" name="details[0][quantity]" required />
          </div>
          <div class="col-md-4">
            <label>Costo Unitario</label>
            <input class="form-control" type="number" step="0.01" min="0" name="details[0][unitCost]" required />
          </div>
        </div>
        <button type="submit" class="btn btn-light mt-4">Guardar compra</button>
      </form>
    </section>
  `
}) %>
