<%- include('../layouts/app-shell', {
  title: 'Compras',
  body: `
    <section class="panel-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title">Compras</h2>
        ${user?.role === 'ADMIN' ? '<a href="/compras/nueva" class="btn btn-light">Nueva compra</a>' : ''}
      </div>
      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
          <thead>
            <tr>
              <th>Nro</th>
              <th>Proveedor</th>
              <th>Fecha</th>
              <th>Estado</th>
              <th>Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            ${(purchases || [])
              .map(
                (purchase) => `
                <tr>
                  <td>${purchase.purchaseNumber}</td>
                  <td>${purchase.supplier?.businessName || '-'}</td>
                  <td>${purchase.purchaseDate}</td>
                  <td><span class="status-pill">${purchase.status}</span></td>
                  <td>$ ${Number(purchase.total).toFixed(2)}</td>
                  <td><a href="/compras/${purchase.id}" class="btn btn-sm btn-outline-light">Ver</a></td>
                </tr>
              `,
              )
              .join('')}
          </tbody>
        </table>
      </div>
    </section>
  `
}) %>
